            padding: 15px;
            border: 2px solid #cbd5e0;
            border-radius: 12px;
            font-size: 18px;
            resize: none;
            direction: ltr;
            text-align: left;
            outline: none;
            transition: all 0.3s;
        }
        textarea:focus {
            border-color: #4c51bf;
            box-shadow: 0 0 10px rgba(76, 81, 191, 0.2);
        }
        .generate-btn {
            background: linear-gradient(135deg, #4c51bf 0%, #667eea 100%);
            color: white;
            border: none;
            padding: 14px 30px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 10px;
            cursor: pointer;
            margin-top: 15px;
            width: 100%;
            transition: all 0.2s;
            box-shadow: 0 4px 15px rgba(76, 81, 191, 0.4);
        }
        .generate-btn:active {
            transform: scale(0.98);
        }
        .generate-btn:hover {
            filter: brightness(1.1);
        }
        .results-container {
            margin-top: 25px;
            max-height: 500px;
            overflow-y: auto;
            padding-left: 5px;
            border-top: 2px dashed #e2e8f0;
            padding-top: 15px;
        }
        .result-box {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 14px;
            border-radius: 10px;
            margin-bottom: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            direction: ltr;
            transition: all 0.2s;
        }
        .result-box:hover {
            background-color: #edf2f7;
            border-color: #cbd5e0;
        }
        .result-text {
            font-size: 19px;
            font-family: 'Courier New', Courier, monospace;
            word-break: break-all;
            color: #1a202c;
            text-align: left;
            flex-grow: 1;
        }
        .copy-btn {
            background-color: #319795;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-family: 'Segoe UI', sans-serif;
            font-size: 14px;
            font-weight: bold;
            transition: all 0.2s;
            white-space: nowrap;
            margin-left: 15px;
        }
        .copy-btn:hover {
            background-color: #2c7a7b;
        }
        .copy-btn.copied {
            background-color: #2b6cb0;
        }
