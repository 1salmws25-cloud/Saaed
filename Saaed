    // لۆژیکی دروستکردنی شێوازی Glitch (Zalgo)
    function makeGlitch(text) {
        const marks = ['\u0305', '\u0332', '\u033f', '\u0311', '\u0306', '\u0310', '\u0352', '\u0351', '\u0325', '\u0326', '\u032b', '\u0328'];
        return text.split('').map(c => {
            let res = c;
            for(let i=0; i<6; i++) {
                res += marks[Math.floor(Math.random() * marks.length)];
            }
            return res;
        }).join('');
    }

    function generateAll() {
        const text = inputText.value.trim();
        if (!text) {
            alert('تکایە سەرەتا دەقەکە لێرە بنووسە!');
            return;
        }

        let results = [];

        // 1. بەشکردنی فۆنتە جێگیرەکان
        Object.keys(alphabets).forEach(key => {
            let converted = text.split('').map(c => alphabets[key][c] || c).join('');
            results.push(converted);
        });

        // 2. فۆنتی سەربەرەوخوار (Flip)
        let flipped = text.split('').reverse().map(c => flipMap[c] || c).join('');
        results.push(flipped);

        // 3. فۆنتی شێوازی تێکەڵاو (پاندا و شەربەتەکە)
        let crazy = text.split('').map(c => crazyChars[c] || c).join('');
        results.push(crazy);

        // 4. فۆنتی Glitch / تێکچوو
        results.push(makeGlitch(text));

        // 5. فۆنتەکانی هێڵکاری (Strike, Underline...)
        results.push(text.split('').join('̶') + '̶');
        results.push(text.split('').join('̴') + '̴');
        results.push(text.split('').join('̲') + '̲');

        // 6. تێکەڵکردنی فۆنتەکان لەگەڵ دیزاینی دەوروبەر
        decorList.forEach(dec => {
            results.push(dec(text));
        });

        // لێرەدا هەموو ئەنجامەکان ڕێکدەخەین و نیشانی دەدەین
        let html = '';
        results.forEach(res => {
            html += `
                <div class="result-box">
                    <span class="result-text">${res}</span>
                    <button class="copy-btn" onclick="copyText(this)">کۆپی</button>
                </div>
            `;
        });
        
        resultsContainer.innerHTML = html;
    }

    function copyText(button) {
        const text = button.previousElementSibling.innerText;
        navigator.clipboard.writeText(text).then(() => {
            button.innerText = 'کۆپی کرا!';
            button.classList.add('copied');
            setTimeout(() => {
                button.innerText = 'کۆپی';
                button.classList.remove('copied');
            }, 1500);
        });
    }

    generateBtn.addEventListener('click', generateAll);
</script>

</body>
</html> 
